# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Packaging / build artifacts (pip, pipx, build, setuptools)
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Grimoire runtime state (generated by fetch/index; user-specific)
#   data/        - cloned sources, native builds, the FTS5 search index
#   sources.yaml backups + the seed marker written by `grimoire sources`
/data/
sources.yaml.bak
.sources.seed.yaml

# Engagement context (may hold target/scope details - keep out of git)
context.yaml

# Editor / OS noise
.DS_Store
*.swp
.idea/
.vscode/
